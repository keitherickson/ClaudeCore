@inject Microsoft.Extensions.Options.IOptions<ClaudeCore.Services.BrandingOptions> Branding
@inject Microsoft.Extensions.Options.IOptions<ClaudeCore.Services.GpuOptions> GpuOpts
@{
    var appName = Branding.Value.AppName;
    var gpuPollMs = Math.Max(250, GpuOpts.Value.PollIntervalMs); // clamp to a sane minimum
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @appName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClaudeCore.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Video" asp-action="Index">@appName</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Video" asp-action="Index">Generate Video</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Upscale" asp-action="Index">Upscale Video</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Speed" asp-action="Index">Speed Up Video</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">Admin</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container small">
            <span id="gpu-footer" title="Live GPU (nvidia-smi)">GPU: …</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Live GPU readout in the footer, polled on every page. -->
    <script>
    (function () {
        const el = document.getElementById("gpu-footer");
        if (!el) return;
        async function poll() {
            try {
                const r = await fetch("/Admin/Gpu");
                const g = await r.json();
                if (g && g.available) {
                    const vram = (g.vramUsedMb != null && g.vramTotalMb != null) ? `${g.vramUsedMb} / ${g.vramTotalMb} MB` : "";
                    const util = g.utilizationPct != null ? `${g.utilizationPct}%` : "";
                    const temp = g.temperatureC != null ? `${g.temperatureC}°C` : "";
                    el.textContent = "GPU: " + [g.name, vram, util, temp].filter(Boolean).join(" · ");
                } else {
                    el.textContent = "GPU: n/a";
                }
            } catch {
                el.textContent = "GPU: n/a";
            }
        }
        poll();
        setInterval(poll, @gpuPollMs);
    })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
