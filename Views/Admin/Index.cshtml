@{
    ViewData["Title"] = "Administration";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Administration</h1>
        <p class="text-muted mb-0">Health of the local services, and controls to recover them.</p>
    </div>
    <button id="refresh-btn" class="btn btn-primary">Refresh</button>
</div>

@Html.AntiForgeryToken()

<div id="updated" class="text-muted small mb-3">Loading…</div>

<!-- Active video model switch -->
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between">
            <h2 class="h5 mb-0">Active Video Model</h2>
            <span id="model-badge" class="badge bg-secondary">…</span>
        </div>
        <p class="text-muted small mt-2 mb-2">Which model the Generate page uses for new videos. The choice is remembered across restarts.</p>
        <div id="model-list" class="d-flex flex-column gap-2"></div>
        <div id="model-status" class="small text-muted mt-2"></div>
    </div>
</div>

<div class="row g-3">
    <!-- LTX video server -->
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">LTX-2.3 Video Server</h2>
                    <span id="ltx-badge" class="badge bg-secondary">…</span>
                </div>
                <dl class="row mb-0 mt-3 small">
                    <dt class="col-5 text-muted">Endpoint</dt><dd class="col-7" id="ltx-endpoint">—</dd>
                    <dt class="col-5 text-muted">Port listening</dt><dd class="col-7" id="ltx-port">—</dd>
                    <dt class="col-5 text-muted">Model loaded</dt><dd class="col-7" id="ltx-model">—</dd>
                    <dt class="col-5 text-muted">GPU</dt><dd class="col-7" id="ltx-gpu">—</dd>
                    <dt class="col-5 text-muted">VRAM</dt><dd class="col-7" id="ltx-vram">—</dd>
                </dl>
                <div id="ltx-error" class="alert alert-danger d-none mt-3 mb-0 small" role="alert"></div>
                <hr class="my-3" />
                <button id="restart-btn" class="btn btn-primary btn-sm">Restart LTX server</button>
                <span id="restart-status" class="ms-2 small text-muted"></span>
                <div id="restart-progress" class="progress d-none mt-2" role="progressbar" style="height: 1.25rem;">
                    <div id="restart-bar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                </div>
                <pre id="restart-output" class="d-none small mt-2 mb-0 p-2 bg-dark border rounded" style="white-space: pre-wrap;"></pre>
            </div>
        </div>

        <!-- AI sound server (Stable Audio) -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">AI Sound Server (Stable Audio)</h2>
                    <span id="audio-badge" class="badge bg-secondary">…</span>
                </div>
                <dl class="row mb-0 mt-3 small">
                    <dt class="col-5 text-muted">Endpoint</dt><dd class="col-7" id="audio-endpoint">—</dd>
                    <dt class="col-5 text-muted">Port listening</dt><dd class="col-7" id="audio-port">—</dd>
                    <dt class="col-5 text-muted">Model loaded</dt><dd class="col-7" id="audio-model">—</dd>
                </dl>
                <div id="audio-error" class="alert alert-warning d-none mt-3 mb-0 small" role="alert"></div>
                <hr class="my-3" />
                <button id="audio-start-btn" class="btn btn-primary btn-sm">Start</button>
                <button id="audio-stop-btn" class="btn btn-primary btn-sm">Stop</button>
                <span id="audio-status" class="ms-2 small text-muted"></span>
                <p class="text-muted small mt-2 mb-0">Not started on logon — start it here when you want AI sound generation. The model takes ~30–60s to load and holds some GPU memory while running.</p>
            </div>
        </div>

        <!-- ffmpeg (on-demand exe) -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">ffmpeg</h2>
                    <span id="ffmpeg-badge" class="badge bg-secondary">…</span>
                </div>
                <div id="ffmpeg-error" class="alert alert-danger d-none mt-3 mb-0 small" role="alert"></div>
                <p class="text-muted small mt-2 mb-1">On-demand — used for speed-up + H.264 conversion.</p>
                <div class="small text-muted text-break" id="ffmpeg-path">—</div>
            </div>
        </div>
    </div>

    <!-- Maxine + app -->
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">NVIDIA Maxine Upscaler</h2>
                    <span id="maxine-badge" class="badge bg-secondary">…</span>
                </div>
                <div id="maxine-error" class="alert alert-danger d-none mt-3 mb-0 small" role="alert"></div>
                <p class="text-muted small mt-2 mb-0">On-demand effect — runs per upscale job, not a background server.</p>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h2 class="h5 mb-3">Web App</h2>
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Version</dt><dd class="col-7" id="app-version">—</dd>
                    <dt class="col-5 text-muted">Machine</dt><dd class="col-7" id="app-machine">—</dd>
                    <dt class="col-5 text-muted">Uptime</dt><dd class="col-7" id="app-uptime">—</dd>
                    <dt class="col-5 text-muted">Output disk</dt><dd class="col-7" id="app-disk">—</dd>
                </dl>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h2 class="h5 mb-2">Staging files</h2>
                <p class="text-muted small mb-2">Uploaded inputs + temp transcodes — safe to clear (your finished videos are not touched).</p>
                <dl class="row mb-2 small">
                    <dt class="col-5 text-muted">Files</dt><dd class="col-7" id="staging-files">—</dd>
                    <dt class="col-5 text-muted">Size</dt><dd class="col-7" id="staging-size">—</dd>
                </dl>
                <button id="clean-btn" class="btn btn-primary btn-sm">Clean staging files</button>
                <span id="clean-status" class="ms-2 small text-muted"></span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const $ = id => document.getElementById(id);
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    function badge(el, ok, okText, badText) {
        el.className = "badge " + (ok ? "bg-success" : "bg-danger");
        el.textContent = ok ? okText : badText;
    }

    function fmtUptime(s) {
        s = Math.max(0, Math.floor(s));
        const d = Math.floor(s / 86400); s -= d * 86400;
        const h = Math.floor(s / 3600); s -= h * 3600;
        const m = Math.floor(s / 60);
        const parts = [];
        if (d) parts.push(d + "d");
        if (h || d) parts.push(h + "h");
        parts.push(m + "m");
        return parts.join(" ");
    }

    async function loadStatus() {
        $("updated").textContent = "Refreshing…";
        try {
            const r = await fetch("/Admin/Status");
            const d = await r.json();

            // LTX
            const ltx = d.ltx || {};
            const h = ltx.health;
            badge($("ltx-badge"), ltx.reachable, "online", "offline");
            $("ltx-endpoint").textContent = "http://127.0.0.1:" + (ltx.port ?? "?");
            $("ltx-port").textContent = ltx.portListening ? "yes" : "no";
            if (h) {
                $("ltx-model").textContent = h.models_loaded
                    ? ("yes" + (h.active_model ? " (" + h.active_model + ")" : ""))
                    : "no — loads on first generation";
                const g = h.gpu_info || {};
                $("ltx-gpu").textContent = g.name || "—";
                $("ltx-vram").textContent = (g.vram != null)
                    ? `${g.vramUsed ?? 0} / ${g.vram} MB used`
                    : "—";
            } else {
                $("ltx-model").textContent = "—";
                $("ltx-gpu").textContent = "—";
                $("ltx-vram").textContent = "—";
            }
            const ltxErr = $("ltx-error");
            ltxErr.classList.toggle("d-none", !ltx.error);
            if (ltx.error) ltxErr.textContent = "Cannot reach server: " + ltx.error;

            // Audio (Stable Audio) server
            const au = d.audio || {};
            const ab = $("audio-badge");
            if (au.reachable) { ab.className = "badge bg-success"; ab.textContent = "online"; }
            else if (au.portListening) { ab.className = "badge bg-warning text-dark"; ab.textContent = "starting…"; }
            else { ab.className = "badge bg-secondary"; ab.textContent = "stopped"; }
            $("audio-endpoint").textContent = "http://127.0.0.1:" + (au.port ?? "?");
            $("audio-port").textContent = au.portListening ? "yes" : "no";
            $("audio-model").textContent = au.reachable ? "yes" : (au.portListening ? "loading…" : "no");
            // Only surface an error when the port is up but the model isn't (a real
            // problem); a simply-stopped server is a normal state, not an error.
            const auErr = $("audio-error");
            const showAuErr = au.error && au.portListening && !au.reachable;
            auErr.classList.toggle("d-none", !showAuErr);
            if (showAuErr) auErr.textContent = au.error;

            // Maxine
            const mx = d.maxine || {};
            badge($("maxine-badge"), mx.ready, "ready", "not ready");
            const mxErr = $("maxine-error");
            mxErr.classList.toggle("d-none", !mx.error);
            if (mx.error) mxErr.textContent = mx.error;

            // ffmpeg
            const ff = d.ffmpeg || {};
            badge($("ffmpeg-badge"), ff.ready, "ready", "not found");
            const ffErr = $("ffmpeg-error");
            ffErr.classList.toggle("d-none", !ff.error);
            if (ff.error) ffErr.textContent = ff.error;
            $("ffmpeg-path").textContent = ff.path || "—";

            // Staging
            const st = d.staging || {};
            $("staging-files").textContent = st.files != null ? st.files : "—";
            $("staging-size").textContent = st.mb != null ? st.mb + " MB" : "—";

            // App
            const app = d.app || {};
            $("app-version").textContent = app.version || "—";
            $("app-machine").textContent = app.machine || "—";
            $("app-uptime").textContent = app.uptimeSeconds != null ? fmtUptime(app.uptimeSeconds) : "—";
            const o = d.output || {};
            $("app-disk").textContent = o.freeGb != null
                ? `${o.freeGb} GB free of ${o.totalGb} GB (${o.drive})`
                : (o.path || "—");

            $("updated").textContent = "Last updated " + new Date().toLocaleTimeString();
        } catch (err) {
            $("updated").textContent = "Failed to load status: " + err.message;
        }
    }

    // Restart: confirm, POST, then poll status a few times so recovery shows live
    // even though the dashboard itself is manual-refresh.
    $("restart-btn").addEventListener("click", async function () {
        if (!confirm("Restart the LTX video server? In-progress generations will be interrupted.")) return;
        const btn = $("restart-btn");
        const status = $("restart-status");
        const out = $("restart-output");
        const progress = $("restart-progress");
        const bar = $("restart-bar");

        // The restart is a single blocking call with no per-step reporting, so we
        // animate a client-side estimate toward ~90% over the expected ~30s and
        // snap to 100% when the call returns.
        const setBar = pct => { bar.style.width = pct + "%"; bar.textContent = pct + "%"; };
        let estimate = 0;
        const expectedMs = 30000;
        const start = Date.now();
        const ticker = setInterval(() => {
            const elapsed = Date.now() - start;
            const target = 90 * (1 - Math.exp(-elapsed / expectedMs)); // ease toward 90%
            estimate = Math.max(estimate, target);
            setBar(Math.round(estimate));
        }, 250);

        btn.disabled = true;
        status.textContent = "Restarting… this can take up to ~30s.";
        out.classList.add("d-none");
        bar.classList.remove("bg-danger");
        setBar(0);
        progress.classList.remove("d-none");
        try {
            const r = await fetch("/Admin/RestartLtx", {
                method: "POST",
                headers: { "RequestVerificationToken": token }
            });
            const d = await r.json();
            clearInterval(ticker);
            setBar(100);
            if (!d.ok) bar.classList.add("bg-danger");
            status.textContent = d.ok ? "Restart complete." : "Restart reported a problem.";
            if (d.output) { out.textContent = d.output; out.classList.remove("d-none"); }
            // Let 100% register briefly, then hide the bar — it only shows while restarting.
            await new Promise(res => setTimeout(res, 800));
            progress.classList.add("d-none");
            // Show the server coming back: re-check a few times.
            for (let i = 0; i < 5; i++) { await new Promise(res => setTimeout(res, 2000)); await loadStatus(); }
        } catch (err) {
            clearInterval(ticker);
            setBar(100);
            bar.classList.add("bg-danger");
            status.textContent = "Restart failed: " + err.message;
            await new Promise(res => setTimeout(res, 800));
            progress.classList.add("d-none");
        } finally {
            btn.disabled = false;
        }
    });

    // Start audio server: POST, then poll status until it comes online (model load ~30-60s).
    $("audio-start-btn").addEventListener("click", async function () {
        const btn = $("audio-start-btn");
        const status = $("audio-status");
        btn.disabled = true;
        status.textContent = "Starting… the model loads in ~30–60s.";
        try {
            const r = await fetch("/Admin/StartAudio", {
                method: "POST",
                headers: { "RequestVerificationToken": token }
            });
            const d = await r.json();
            if (!d.ok) { status.textContent = "Start failed: " + (d.error || "see logs"); return; }
            let online = false;
            for (let i = 0; i < 30 && !online; i++) {
                await new Promise(res => setTimeout(res, 3000));
                await loadStatus();
                online = $("audio-badge").textContent === "online";
            }
            status.textContent = online ? "Started." : "Still loading — use Refresh to check.";
        } catch (err) {
            status.textContent = "Start failed: " + err.message;
        } finally {
            btn.disabled = false;
        }
    });

    // Stop audio server: confirm, POST, refresh.
    $("audio-stop-btn").addEventListener("click", async function () {
        if (!confirm("Stop the AI sound server? It frees its GPU memory; AI sound generation won't work until you start it again.")) return;
        const btn = $("audio-stop-btn");
        const status = $("audio-status");
        btn.disabled = true;
        status.textContent = "Stopping…";
        try {
            const r = await fetch("/Admin/StopAudio", {
                method: "POST",
                headers: { "RequestVerificationToken": token }
            });
            const d = await r.json();
            status.textContent = d.ok ? (d.output || "Stopped.") : "Stop reported a problem.";
            await loadStatus();
        } catch (err) {
            status.textContent = "Stop failed: " + err.message;
        } finally {
            btn.disabled = false;
        }
    });

    // Clean staging files: confirm, POST, then refresh the status.
    $("clean-btn").addEventListener("click", async function () {
        if (!confirm("Delete staged uploads and temp transcodes? Finished videos are not affected.")) return;
        const btn = $("clean-btn");
        const status = $("clean-status");
        btn.disabled = true;
        status.textContent = "Cleaning…";
        try {
            const r = await fetch("/Admin/CleanStaging", {
                method: "POST",
                headers: { "RequestVerificationToken": token }
            });
            const d = await r.json();
            status.textContent = d.ok ? `Removed ${d.files} file(s), freed ${d.mb} MB.` : "Cleanup failed.";
            await loadStatus();
        } catch (err) {
            status.textContent = "Cleanup failed: " + err.message;
        } finally {
            btn.disabled = false;
        }
    });

    // Active video model: render the registry as radios and switch on change.
    async function loadModels() {
        try {
            const r = await fetch("/Admin/Models");
            const d = await r.json();
            if (!d.ok) return;
            const list = $("model-list");
            list.innerHTML = "";
            const active = d.models.find(m => m.id === d.activeId);
            const badge = $("model-badge");
            badge.className = "badge bg-success";
            badge.textContent = active ? active.label : d.activeId;
            for (const m of d.models) {
                const id = "model-" + m.id;
                const row = document.createElement("div");
                row.className = "form-check";
                row.innerHTML =
                    '<input class="form-check-input" type="radio" name="active-model" id="' + id + '" value="' + m.id + '"'
                    + (m.id === d.activeId ? " checked" : "") + '>'
                    + '<label class="form-check-label" for="' + id + '"><strong>' + m.label + '</strong>'
                    + '<span class="text-muted small d-block">' + (m.description || "") + '</span></label>';
                row.querySelector("input").addEventListener("change", () => switchModel(m.id));
                list.appendChild(row);
            }
        } catch (err) {
            $("model-status").textContent = "Failed to load models: " + err.message;
        }
    }

    async function switchModel(id) {
        const status = $("model-status");
        status.textContent = "Switching…";
        // Disable the radios while the backend lifecycle runs.
        const radios = document.querySelectorAll('input[name="active-model"]');
        radios.forEach(r => r.disabled = true);
        try {
            const body = new URLSearchParams({ id });
            const r = await fetch("/Admin/SetModel", {
                method: "POST",
                headers: { "RequestVerificationToken": token, "Content-Type": "application/x-www-form-urlencoded" },
                body
            });
            const d = await r.json();
            if (!d.ok) { status.textContent = "Switch failed: " + (d.error || "see logs"); return; }

            const stopped = (d.stopped && d.stopped.length) ? " (freed " + d.stopped.join(", ") + ")" : "";
            if (d.backendWasUp) {
                status.textContent = "Active model updated — " + d.backend + " already running" + stopped + ".";
            } else {
                // The backend was just started (detached); poll Status until its port binds.
                status.textContent = "Starting " + d.backend + "…" + stopped + " this can take ~30–90s.";
                const upKey = d.backend === "ComfyUI" ? "comfy" : "ltx";
                let online = false;
                for (let i = 0; i < 40 && !online; i++) {
                    await new Promise(res => setTimeout(res, 3000));
                    try {
                        const s = await (await fetch("/Admin/Status")).json();
                        online = s.ok && s[upKey] && s[upKey].portListening;
                    } catch { /* keep polling */ }
                }
                status.textContent = online
                    ? d.backend + " is up. (Model weights load on the first generation.)"
                    : "Still starting " + d.backend + " — use Refresh to check.";
            }
            await loadModels();
            await loadStatus();
        } catch (err) {
            status.textContent = "Switch failed: " + err.message;
        } finally {
            radios.forEach(r => r.disabled = false);
        }
    }

    $("refresh-btn").addEventListener("click", () => { loadStatus(); loadModels(); });
    loadStatus();
    loadModels();
})();
</script>
}
