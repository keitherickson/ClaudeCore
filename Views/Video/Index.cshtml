@inject Microsoft.Extensions.Options.IOptions<ClaudeCore.Services.VideoDefaultsOptions> VideoDefaults
@{
    ViewData["Title"] = "Generate Video (LTX-2.3)";
    var vd = VideoDefaults.Value;
}

<div class="row">
    <div class="col-lg-7">
        <h1 class="h3 mb-1">Generate Video</h1>
        <p class="text-muted">
            Local LTX-2.3 on your RTX 5090 — text-to-video, or upload an image for image-to-video.
            <span id="ltx-status" class="badge bg-secondary">checking server…</span>
        </p>

        <form id="gen-form">
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Prompt
                    <a href="#" id="clear-saved-prompt" class="ms-2 small fw-normal d-none">clear saved prompt</a>
                </label>
                <textarea name="prompt" class="form-control" rows="3" required
                          placeholder="A red fox trotting through a snowy forest, cinematic lighting"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Starting image <span class="text-muted fw-normal">(optional — enables image-to-video)</span></label>
                <input type="file" name="image" id="image" class="form-control" accept="image/*" />
                <div id="saved-image" class="form-text d-none">
                    Reusing saved image: <code id="saved-image-path"></code>
                    <a href="#" id="clear-saved-image" class="ms-1">clear</a>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <label class="form-label">Resolution</label>
                    <select name="resolution" id="resolution" class="form-select"></select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Duration</label>
                    <select name="duration" id="duration" class="form-select"></select>
                    <div class="form-text">Longer clips need lower resolution.</div>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">FPS</label>
                    <select name="fps" id="fps" class="form-select"></select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Aspect</label>
                    <select name="aspectRatio" class="form-select">
                        <option value="16:9" selected>16:9</option>
                        <option value="9:16">9:16</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-6 col-md-3">
                    <label class="form-label">Camera motion</label>
                    <select name="cameraMotion" class="form-select">
                        <option value="none" selected>None</option>
                        <option value="static">Static</option>
                        <option value="dolly_in">Dolly in</option>
                        <option value="dolly_out">Dolly out</option>
                        <option value="dolly_left">Dolly left</option>
                        <option value="dolly_right">Dolly right</option>
                        <option value="jib_up">Jib up</option>
                        <option value="jib_down">Jib down</option>
                        <option value="focus_shift">Focus shift</option>
                    </select>
                </div>
                <div class="col-md-9">
                    <label class="form-label">Negative prompt <span class="text-muted">(optional)</span></label>
                    <input type="text" name="negativePrompt" class="form-control" placeholder="blurry, distorted, low quality" />
                </div>
            </div>

            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" name="audio" value="true" id="audio" />
                <label class="form-check-label" for="audio">Generate synchronized audio</label>
            </div>

            <hr class="my-3" />
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="upscale" value="true" id="upscale" />
                <label class="form-check-label fw-semibold" for="upscale">
                    Upscale with NVIDIA Maxine <span class="text-muted fw-normal">(saves an upscaled copy too)</span>
                </label>
            </div>
            <div class="row g-3 mt-0 d-none" id="upscale-opts">
                <div class="col-6 col-md-4">
                    <label class="form-label">Upscale factor</label>
                    <select name="upscaleFactor" id="upscaleFactor" class="form-select">
                        <option value="2" selected>2&times;</option>
                        <option value="3">3&times;</option>
                        <option value="4">4&times;</option>
                    </select>
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label">Source quality</label>
                    <select name="upscaleMode" id="upscaleMode" class="form-select">
                        <option value="1" selected>Clean</option>
                        <option value="0">Compressed</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="speedUp" value="true" id="speedUp" />
                        <label class="form-check-label" for="speedUp">Play faster <span class="text-muted">(after upscaling)</span></label>
                    </div>
                    <select name="speedFactor" id="speedFactor" class="form-select mt-1 d-none">
                        <option value="1.5">1.5&times; speed</option>
                        <option value="2" selected>2&times; speed</option>
                        <option value="3">3&times; speed</option>
                        <option value="4">4&times; speed</option>
                    </select>
                </div>
            </div>

            <button type="submit" id="gen-btn" class="btn btn-primary mt-3">Generate</button>
        </form>
    </div>

    <div class="col-lg-5">
        <div id="progress-card" class="card d-none mt-4 mt-lg-0">
            <div class="card-body">
                <h2 class="h6 card-title mb-2">Generating…</h2>
                <div class="progress" role="progressbar" style="height: 1.25rem;">
                    <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                </div>
                <p id="progress-phase" class="text-muted small mt-2 mb-0"></p>
            </div>
        </div>

        <div id="result-card" class="card d-none mt-4 mt-lg-0">
            <div class="card-body">
                <h2 class="h6 card-title">Result</h2>
                <video id="result-video" class="w-100 rounded border" controls></video>
                <p id="result-path" class="text-muted small mt-2 mb-1"></p>
                <a id="result-download" class="btn btn-sm btn-primary" download>Download .mp4</a>
            </div>
        </div>

        <div id="upscaled-card" class="card d-none mt-3">
            <div class="card-body">
                <h2 class="h6 card-title">Upscaled (NVIDIA Maxine)</h2>
                <video id="upscaled-video" class="w-100 rounded border" controls></video>
                <p id="upscaled-path" class="text-muted small mt-2 mb-1"></p>
                <a id="upscaled-download" class="btn btn-sm btn-primary" download>Download upscaled .mp4</a>
            </div>
        </div>

        <div id="upscale-warning" class="alert alert-warning d-none mt-3" role="alert"></div>

        <button type="button" id="clear-videos" class="btn btn-primary btn-sm d-none mt-3">Clear Video</button>

        <div id="error-card" class="alert alert-danger d-none mt-4 mt-lg-0" role="alert"></div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const form = document.getElementById("gen-form");
    const btn = document.getElementById("gen-btn");
    const statusBadge = document.getElementById("ltx-status");
    const progressCard = document.getElementById("progress-card");
    const progressBar = document.getElementById("progress-bar");
    const progressPhase = document.getElementById("progress-phase");
    const resultCard = document.getElementById("result-card");
    const resultVideo = document.getElementById("result-video");
    const resultPath = document.getElementById("result-path");
    const resultDownload = document.getElementById("result-download");
    const errorCard = document.getElementById("error-card");
    const upscaleChk = document.getElementById("upscale");
    const upscaleOpts = document.getElementById("upscale-opts");
    const speedUpChk = document.getElementById("speedUp");
    const speedFactorSel = document.getElementById("speedFactor");
    const upscaledCard = document.getElementById("upscaled-card");
    const upscaledVideo = document.getElementById("upscaled-video");
    const upscaledPath = document.getElementById("upscaled-path");
    const upscaledDownload = document.getElementById("upscaled-download");
    const upscaleWarning = document.getElementById("upscale-warning");
    const clearVideosBtn = document.getElementById("clear-videos");

    // Remove the shown videos and hide this button.
    clearVideosBtn.addEventListener("click", function () {
        for (const v of [resultVideo, upscaledVideo]) { v.removeAttribute("src"); v.load(); }
        resultCard.classList.add("d-none");
        upscaledCard.classList.add("d-none");
        upscaleWarning.classList.add("d-none");
        clearVideosBtn.classList.add("d-none");
    });

    upscaleChk.addEventListener("change", function () {
        upscaleOpts.classList.toggle("d-none", !upscaleChk.checked);
    });

    speedUpChk.addEventListener("change", function () {
        speedFactorSel.classList.toggle("d-none", !speedUpChk.checked);
    });

    let pollTimer = null;
    let estimate = 0; // smoothed client-side estimate (backend reports coarse jumps)

    // Form defaults from server config (appsettings.json -> VideoDefaults).
    const DEFAULTS = {
        resolution: "@vd.Resolution",
        duration: @vd.Duration,
        fps: @vd.Fps,
        aspectRatio: "@vd.AspectRatio",
        cameraMotion: "@vd.CameraMotion",
        audio: @(vd.Audio ? "true" : "false")
    };

    // --- Capability matrix: which durations/fps are valid per resolution ---
    // Pulled live from the server; this is the offline fallback (LTX 2.3 Fast).
    const FALLBACK_MATRIX = {
        "540p": { "24": [5, 6, 8, 10, 20] },
        "720p": { "24": [5, 6, 8, 10] },
        "1080p": { "24": [5] }
    };
    let matrix = FALLBACK_MATRIX;

    const resSel = document.getElementById("resolution");
    const fpsSel = document.getElementById("fps");
    const durSel = document.getElementById("duration");

    function fillSelect(sel, values, fmt) {
        const prev = sel.value;
        sel.innerHTML = "";
        for (const v of values) {
            const o = document.createElement("option");
            o.value = v;
            o.textContent = fmt ? fmt(v) : v;
            sel.appendChild(o);
        }
        if (values.map(String).includes(prev)) sel.value = prev; // preserve choice if still valid
    }

    function populateDurations(useDefaults) {
        const list = ((matrix[resSel.value] || {})[fpsSel.value] || []).slice().sort((a, b) => a - b);
        fillSelect(durSel, list, v => v + " s");
        if (useDefaults && list.map(String).includes(String(DEFAULTS.duration))) durSel.value = String(DEFAULTS.duration);
    }

    function populateFps(useDefaults) {
        const list = Object.keys(matrix[resSel.value] || {}).sort((a, b) => a - b);
        fillSelect(fpsSel, list);
        if (useDefaults && list.map(String).includes(String(DEFAULTS.fps))) fpsSel.value = String(DEFAULTS.fps);
        populateDurations(useDefaults);
    }

    function populateResolutions(useDefaults) {
        const resos = Object.keys(matrix).sort((a, b) => parseInt(a) - parseInt(b));
        fillSelect(resSel, resos);
        if (useDefaults && resos.includes(DEFAULTS.resolution)) resSel.value = DEFAULTS.resolution;
        else if (!resos.includes(resSel.value) && resos.length) resSel.value = resos[0];
        populateFps(useDefaults);
    }

    async function loadSpecs() {
        try {
            const r = await fetch("/Video/Specs");
            const data = await r.json();
            const models = data.local_models || [];
            const fast = models.find(m => m.pipeline === "fast") || models[0];
            const srd = fast && fast.spec && fast.spec.supported_resolutions_durations;
            if (srd) {
                const m = {};
                for (const res of Object.keys(srd)) m[res] = srd[res].fps_to_durations || {};
                if (Object.keys(m).length) matrix = m;
            }
        } catch { /* keep fallback */ }
        populateResolutions(true);
    }

    resSel.addEventListener("change", () => populateFps(false));
    fpsSel.addEventListener("change", () => populateDurations(false));

    // Apply config defaults to the static fields.
    form.elements["cameraMotion"].value = DEFAULTS.cameraMotion;
    form.elements["aspectRatio"].value = DEFAULTS.aspectRatio;
    form.elements["audio"].checked = DEFAULTS.audio;

    // --- Persisted prompt (localStorage) + server-remembered starting image ---
    const PROMPT_KEY = "keithvision.prompt";
    const clearSavedPromptLink = document.getElementById("clear-saved-prompt");
    const imageInput = document.getElementById("image");
    const savedImageBox = document.getElementById("saved-image");
    const savedImagePathEl = document.getElementById("saved-image-path");

    // Show the "clear saved prompt" link only when a prompt is saved in localStorage.
    function showSavedPrompt() {
        clearSavedPromptLink.classList.toggle("d-none", !localStorage.getItem(PROMPT_KEY));
    }
    // The last image is remembered server-side; rendered here so it shows on load.
    let savedImagePath = @Json.Serialize(ViewData["LastImage"]);

    function showSavedImage() {
        savedImagePathEl.textContent = savedImagePath || "";
        const hasNewFile = imageInput.files && imageInput.files.length > 0;
        savedImageBox.classList.toggle("d-none", !savedImagePath || hasNewFile);
    }

    // Restore the prompt from localStorage; the image comes from the server.
    (function restorePersisted() {
        const p = localStorage.getItem(PROMPT_KEY);
        if (p) form.elements["prompt"].value = p;
        showSavedPrompt();
        showSavedImage();
    })();

    // Clear the remembered prompt (and empty the field); the link then disappears.
    clearSavedPromptLink.addEventListener("click", function (e) {
        e.preventDefault();
        localStorage.removeItem(PROMPT_KEY);
        form.elements["prompt"].value = "";
        showSavedPrompt();
    });

    // A newly chosen file takes precedence over the saved image for this run.
    imageInput.addEventListener("change", showSavedImage);

    document.getElementById("clear-saved-image").addEventListener("click", async function (e) {
        e.preventDefault();
        try { await fetch("/Video/ClearImage", { method: "POST" }); } catch { /* ignore */ }
        savedImagePath = null;
        showSavedImage();
    });

    async function checkHealth() {
        try {
            const r = await fetch("/Video/Health");
            const d = await r.json();
            if (d.ok && d.health) {
                statusBadge.className = "badge bg-success";
                statusBadge.textContent = "server online";
            } else {
                statusBadge.className = "badge bg-danger";
                statusBadge.textContent = "server offline";
            }
        } catch {
            statusBadge.className = "badge bg-danger";
            statusBadge.textContent = "server offline";
        }
    }

    async function poll() {
        try {
            const r = await fetch("/Video/Progress");
            const p = await r.json();
            const real = Math.max(0, Math.min(100, p.progress || 0));

            // The backend reports coarse jumps (5 -> 10 -> 15 -> 100) and pins at
            // 15% for the whole render. Ease a smooth estimate toward a per-phase
            // ceiling, never below the real value, and snap to 100 when complete.
            if (p.status === "complete" || real >= 100) {
                estimate = 100;
            } else {
                const ceiling = (p.phase === "inference") ? 95 : 14;
                const rate = (p.phase === "inference") ? 0.03 : 0.05;
                const base = Math.max(estimate, real);
                estimate = Math.min(ceiling, base + (ceiling - base) * rate);
            }
            const display = Math.round(Math.max(real, estimate));
            progressBar.style.width = display + "%";
            progressBar.textContent = display + "%";

            let phase = p.phase || p.status || "";
            if (p.phase === "inference") phase = "rendering frames (estimated)";
            // Generation done but request still pending => the upscale phase is running.
            if (upscaleChk.checked && (p.status === "complete" || p.status === "idle") && real >= 100) {
                const speedNote = speedUpChk.checked ? ` then ${speedFactorSel.value}x speed-up` : "";
                phase = `generation complete — upscaling ${document.getElementById("upscaleFactor").value}x${speedNote}…`;
            }
            progressPhase.textContent = phase;
        } catch { /* ignore transient poll errors */ }
    }

    form.addEventListener("submit", async function (e) {
        e.preventDefault();
        errorCard.classList.add("d-none");
        resultCard.classList.add("d-none");
        upscaledCard.classList.add("d-none");
        upscaleWarning.classList.add("d-none");
        clearVideosBtn.classList.add("d-none");
        progressCard.classList.remove("d-none");
        progressBar.style.width = "0%";
        progressBar.textContent = "0%";
        progressPhase.textContent = "submitting…";
        estimate = 0;
        btn.disabled = true;

        pollTimer = setInterval(poll, 1000);

        try {
            const data = new FormData(form);
            if (!document.getElementById("audio").checked) data.set("audio", "false");
            if (!upscaleChk.checked) data.set("upscale", "false");
            if (!speedUpChk.checked) data.set("speedUp", "false");
            // No new file? The server automatically reuses the remembered image.

            const resp = await fetch("/Video/Generate", { method: "POST", body: data });
            const result = await resp.json();

            if (resp.ok && result.ok) {
                progressBar.style.width = "100%";
                progressBar.textContent = "100%";
                const url = "/Video/Download?name=" + encodeURIComponent(result.fileName);
                resultVideo.src = url;
                resultDownload.href = url;
                resultPath.textContent = `${result.mode} · saved to ${result.savedPath}`;
                resultCard.classList.remove("d-none");
                clearVideosBtn.classList.remove("d-none");

                // Generation completed => persist prompt (localStorage); the image is
                // already remembered server-side, just sync the UI.
                localStorage.setItem(PROMPT_KEY, form.elements["prompt"].value);
                showSavedPrompt();
                savedImagePath = result.inputImagePath || null;
                if (savedImagePath) imageInput.value = ""; // clear picker; server reuses it next time
                showSavedImage();

                // Upscaled copy (if requested)
                if (result.upscaled) {
                    const uUrl = "/Upscale/Download?name=" + encodeURIComponent(result.upscaled.fileName);
                    upscaledVideo.src = uUrl;
                    upscaledDownload.href = uUrl;
                    const speedNote = result.upscaled.speed ? ` · ${result.upscaled.speed}x speed` : "";
                    upscaledPath.textContent = `${result.upscaled.factor}x → ${result.upscaled.height}p${speedNote} · saved to ${result.upscaled.savedPath}`;
                    upscaledCard.classList.remove("d-none");
                } else if (result.upscaleError) {
                    upscaleWarning.textContent = "Video generated, but upscaling failed: " + result.upscaleError;
                    upscaleWarning.classList.remove("d-none");
                }
            } else {
                throw new Error(result.error || ("HTTP " + resp.status));
            }
        } catch (err) {
            errorCard.textContent = "Generation failed: " + err.message;
            errorCard.classList.remove("d-none");
        } finally {
            clearInterval(pollTimer);
            progressCard.classList.add("d-none");
            btn.disabled = false;
        }
    });

    checkHealth();
    loadSpecs();
})();
</script>
}
