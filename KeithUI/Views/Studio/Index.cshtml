@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KeithUI Studio</title>
    <link rel="stylesheet" href="~/lib/litegraph/litegraph.css" asp-append-version="true" />
    <style>
        :root { color-scheme: dark; }
        html, body { margin: 0; height: 100%; overflow: hidden; background: #1a1a1a;
            font-family: system-ui, "Segoe UI", sans-serif; color: #e6e6e6; }
        #toolbar { position: fixed; top: 0; left: 0; right: 0; height: 44px; z-index: 10;
            display: flex; align-items: center; gap: 12px; padding: 0 14px;
            background: #232323; border-bottom: 1px solid #000; box-sizing: border-box; }
        #toolbar .brand { font-weight: 600; letter-spacing: .3px; }
        #toolbar .brand small { color: #8a8a8a; font-weight: 400; margin-left: 6px; }
        #toolbar .spacer { flex: 1; }
        button { background: #2d6cdf; color: #fff; border: 0; border-radius: 5px;
            padding: 7px 16px; font-size: 13px; cursor: pointer; }
        button:hover { background: #3b78e6; }
        button.ghost { background: #3a3a3a; }
        button.ghost:hover { background: #454545; }
        select.ghost { background: #3a3a3a; color: #fff; border: 0; border-radius: 5px;
            padding: 7px 10px; font-size: 13px; cursor: pointer; max-width: 200px; }
        select.ghost:hover { background: #454545; }
        #toolbar .divider { width: 1px; height: 22px; background: #000; margin: 0 2px; }
        #status { color: #9a9a9a; font-size: 12px; }
        #graph { position: fixed; top: 44px; left: 0; right: 0; bottom: 26px; }
        #footer { position: fixed; left: 0; right: 0; bottom: 0; height: 26px; z-index: 10;
            display: flex; align-items: center; gap: 14px; padding: 0 14px; box-sizing: border-box;
            background: #232323; border-top: 1px solid #000; font-size: 12px; color: #9a9a9a; }
        #result { position: fixed; right: 14px; bottom: 40px; width: 360px; z-index: 20;
            background: #232323; border: 1px solid #000; border-radius: 8px; padding: 10px;
            box-shadow: 0 6px 24px rgba(0,0,0,.5); display: none; }
        #result.show { display: block; }
        #result header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 13px; }
        #result header .ttl { font-weight: 600; flex: 1; }
        #result header .x { cursor: pointer; color: #9a9a9a; }
        #result .log { max-height: 200px; overflow: auto; font: 11px/1.5 ui-monospace, monospace;
            color: #b9b9b9; white-space: pre-wrap; }
    </style>
</head>
<body>
    <div id="toolbar">
        <span class="brand">KeithUI</span>
        <button id="run-btn">▶ Run</button>
        <button id="reset-btn" class="ghost">Reset</button>
        <button id="save-btn" class="ghost" title="Download this graph as JSON">⭳ Save</button>
        <button id="load-btn" class="ghost" title="Load a graph JSON file">⭱ Load</button>
        <input id="load-file" type="file" accept="application/json,.json" style="display:none" />
        <span class="divider"></span>
        <select id="layout-select" class="ghost" title="Load a saved layout">
            <option value="">— saved layouts —</option>
        </select>
        <button id="layout-save-btn" class="ghost" title="Save the current graph as a named layout">＋ Save layout</button>
        <button id="layout-delete-btn" class="ghost" title="Delete the selected layout">🗑</button>
        <span id="status"></span>
        <span class="spacer"></span>
        <span style="color:#6a6a6a;font-size:12px;">right-click canvas to add nodes · drag ports to wire</span>
    </div>
    <canvas id="graph"></canvas>

    <div id="result">
        <header>
            <span class="ttl">Run log</span>
            <span class="x" id="result-close">✕</span>
        </header>
        <div class="log" id="result-log"></div>
    </div>

    <div id="footer">
        <span id="sysstats" title="Live GPU / CPU / RAM (nvidia-smi)">GPU: …</span>
    </div>

    <script src="~/lib/litegraph/litegraph.js" asp-append-version="true"></script>
    <script src="~/js/studio.js" asp-append-version="true"></script>

    <!-- Live system readout in the footer (mirrors the KeithVision footer). -->
    <script>
    (function () {
        var el = document.getElementById("sysstats");
        if (!el) return;
        async function poll() {
            try {
                var d = await (await fetch("/Studio/SystemStats")).json();
                var g = d.gpu || {}, c = d.cpu || {}, mem = d.memory || {};
                var parts = [];
                if (g.available) {
                    var vram = (g.vramUsedMb != null && g.vramTotalMb != null) ? (g.vramUsedMb + " / " + g.vramTotalMb + " MB") : "";
                    var util = g.utilizationPct != null ? (g.utilizationPct + "%") : "";
                    var temp = g.temperatureC != null ? (g.temperatureC + "°C") : "";
                    parts.push("GPU: " + [g.name, vram, util, temp].filter(Boolean).join(" · "));
                } else { parts.push("GPU: n/a"); }
                if (c && c.utilizationPct != null) parts.push("CPU: " + c.utilizationPct + "%");
                if (mem && mem.available && mem.totalMb) {
                    var gb = function (mb) { return (mb / 1024).toFixed(1); };
                    parts.push("RAM: " + gb(mem.usedMb) + " / " + gb(mem.totalMb) + " GB");
                }
                el.textContent = parts.join("   |   ");
            } catch { el.textContent = "GPU: n/a"; }
        }
        poll(); setInterval(poll, 1000);
    })();
    </script>
</body>
</html>
